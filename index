        body {
            -webkit-user-select: none;  
            -moz-user-select: none;     
            -ms-user-select: none;      
            user-select: none;          
        }

        img {
            -webkit-user-drag: none;
            -khtml-user-drag: none;
            -moz-user-drag: none;
            -o-user-drag: none;
            user-drag: none;
            pointer-events: none; 
        }

        @media (max-width: 992px) {
            body { 
                padding: 10px;
                overflow-y: auto; 
                align-items: flex-start;
            }
            .modal-window { 
                max-width: 100vw; 
                width: 100%;
                height: auto; 
