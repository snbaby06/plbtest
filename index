    // ==========================================================================
    // NEW: REAL-TIME COUNTDOWN TIMER JAVASCRIPT ENGINE
    // ==========================================================================
    const targetConcertDate = new Date("October 10, 2026 18:00:00").getTime();

    const countdownTimerEngine = setInterval(function() {
        const now = new Date().getTime();
        const distance = targetConcertDate - now;

        // คำนวณช่วงหน่วยเวลา Days, Hours, Minutes, Seconds
        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        // นำค่าไปยัดลงใน DOM Element และป้องกันเลขตัวเดียวกระตุกด้วยการทำ PadStart '0'
        document.getElementById("count-days").innerHTML = String(days).padStart(2, '0');
        document.getElementById("count-hours").innerHTML = String(hours).padStart(2, '0');
        document.getElementById("count-minutes").innerHTML = String(minutes).padStart(2, '0');
        document.getElementById("count-seconds").innerHTML = String(seconds).padStart(2, '0');

        // หากหมดเวลานับถอยหลัง (ถึงเวลาคอนเสิร์ตแล้ว)
        if (distance < 0) {
            clearInterval(countdownTimerEngine);
            document.querySelector(".countdown-grid").innerHTML = "<div style='color: #ff002b; font-weight: bold; font-size: 1.2rem; letter-spacing: 1px;'>🛸 SHOWTIME IS NOW! IT'S MANIC! 🛸</div>";
        }
    }, 1000);

    // ฟังก์ชันคำนวณราคาสรุปยอดสุทธิ
    function calculateTicketPrice(priceStr, element) {
        const price = parseFloat(priceStr);
        const ticketFee = 30; 
        const processingFee = price * 0.03;
        const total = price + ticketFee + processingFee;

        document.getElementById('base-price-text').textContent = price.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});
        document.getElementById('fee-price-text').textContent = (ticketFee + processingFee).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});
        document.getElementById('total-price-text').textContent = total.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});

        const formattedPrice = priceStr === '6800' ? 'VIP 6,800 ฿' : `${Number(priceStr).toLocaleString()} ฿`;
        document.getElementById('selected-calc-title').textContent = `📊 จำนวนเงินที่ต้องชำระสำหรับบัตรราคา ${formattedPrice}`;

        // ล้างปุ่มคำนวณปุ่มอื่นให้กลับสู่สภาพเดิม
        const allCalcButtons = document.querySelectorAll('.zone-btn-calc');
        allCalcButtons.forEach(btn => {
            btn.style.setProperty('background-color', '', 'important');
            btn.style.setProperty('color', '', 'important');
            btn.style.setProperty('border-color', '', 'important');
            btn.style.setProperty('box-shadow', '', 'important');
        });

        const calcHeaderBox = document.getElementById('calc-details-header');
        const calcBorderBox = document.getElementById('calc-details-box');

        if (zoneColors[priceStr]) {
            const theme = zoneColors[priceStr];
            if(element && element.classList.contains('zone-btn-calc')) {
                element.style.setProperty('background-color', theme.bg, 'important');
                element.style.setProperty('color', theme.text, 'important');
                element.style.setProperty('border-color', theme.bg, 'important');
                element.style.setProperty('box-shadow', `0 0 12px ${theme.glow}`, 'important');
            }

            if (calcHeaderBox) {
                calcHeaderBox.style.setProperty('background-color', theme.bg, 'important');
                calcHeaderBox.style.setProperty('color', theme.text, 'important');
            }
            if (calcBorderBox) {
                calcBorderBox.style.setProperty('border-color', theme.bg, 'important');
            }
        }
    }

    // ฟังก์ชันเชื่อมโยง Event บนแผนผัง SVG เข้าสู่กลไกการคำนวณราคา
    document.addEventListener("DOMContentLoaded", function() {
        const svgZones = document.querySelectorAll(".concert-svg-map .st-zone");
        
        svgZones.forEach(zone => {
            zone.addEventListener("click", function() {
                // ล้าง Class แอคทีฟที่เคยเลือกไว้ทั้งหมดบนผังก่อน
