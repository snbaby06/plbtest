                // ใส่สไตล์เปิดรับเอฟเฟกต์เรืองแสงที่ตัวโซนที่ถูกกด
                this.classList.add("selected-active");
                
                const targetPrice = this.getAttribute("data-price");
                const zoneName = this.getAttribute("data-zone");
                
                // เรียกกลไกแสดงผลรวมเงินหลัก
                calculateTicketPrice(targetPrice, null);
                
                // แนบชื่อโซนสลักทับบน Header บล็อกสถิติย่อย
                const formattedPrice = targetPrice === '6800' ? 'VIP 6,800 ฿' : `${Number(targetPrice).toLocaleString()} ฿`;
                document.getElementById('selected-calc-title').textContent = `📊 โซนที่เลือก: ${zoneName} (ราคา ${formattedPrice})`;
            });
        });
    });

    // ฟังก์ชันดึงชุดข้อมูลสิทธิประโยชน์ (Benefits Tab)
    function selectZone(zonePrice, element) {
