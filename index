            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.15);
            color: var(--text-light-main);
            padding: 10px 20px;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            transition: transform 0.2s, background 0.2s;
        }
        .zone-btn-calc:hover {
            background: rgba(255, 255, 255, 0.15);
            transform: translateY(-2px);
        }

        .button-group {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .right-content-viewer::-webkit-scrollbar { width: 5px; }
        .right-content-viewer::-webkit-scrollbar-track { background: transparent; }
        .right-content-viewer::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.12); border-radius: 10px; }
        .right-content-viewer::-webkit-scrollbar-thumb:hover { background: var(--neon-red); }

        /* ==========================================================================
           4. MOBILE RESPONSIVE & PROTECTION STYLES
