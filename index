            }
            .right-content-viewer { 
                padding: 20px 15px; 
            }
            .overview-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }
            .poster-box {
                max-width: 320px;
                margin: 0 auto;
            }
            .section-title {
                font-size: 1.25rem;
                margin-bottom: 20px;
                padding-bottom: 10px;
            }
            .bullet-list li, .bullet-list-interactive li {
                font-size: 0.9rem;
                margin-bottom: 14px;
            }
            .zone-buttons, .button-group {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 8px;
            }
            .zone-btn, .zone-btn-calc {
                width: 100% !important;
                padding: 10px 5px !important;
                font-size: 0.85rem !important;
                text-align: center;
            }
            .countdown-grid {
                justify-content: center;
            }
        }
    </style>
</head>
