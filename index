        const listElement = document.getElementById('benefits-list');
        
        const benefitHeaderBox = document.getElementById('benefit-details-header');
        const benefitBorderBox = document.getElementById('benefit-details-box');

        const data = concertBenefitData[zonePrice];
        if (data) {
            titleElement.textContent = data.title;
            listElement.innerHTML = "";

            data.benefits.forEach(benefit => {
                const li = document.createElement('li');
                li.textContent = benefit;
                listElement.appendChild(li);
            });

            if (zoneColors[zonePrice]) {
                const theme = zoneColors[zonePrice];
                element.style.setProperty('background-color', theme.bg, 'important');
                element.style.setProperty('color', theme.text, 'important');
                element.style.setProperty('border-color', theme.bg, 'important');
                element.style.setProperty('box-shadow', `0 0 12px ${theme.glow}`, 'important');

                if (benefitHeaderBox) {
                    benefitHeaderBox.style.setProperty('background-color', theme.bg, 'important');
                    benefitHeaderBox.style.setProperty('color', theme.text, 'important');
                }
                if (benefitBorderBox) {
                    benefitBorderBox.style.setProperty('border-color', theme.bg, 'important');
                }
            }
        }
    }

    // นับถอย Weverse Presale & Concert Day
    function initDualCountdown() {
        // 1. ตั้งเวลาเป้าหมายรอบ Weverse Presale: 1 สิงหาคม 2026 เวลา 11:00:00 น.
        const presaleTarget = new Date("August 1, 2026 11:00:00").getTime();
        // 2. ตั้งเวลาเป้าหมายวันคอนเสิร์ต: 10 ตุลาคม 2026 เวลา 18:00:00 น.
        const concertTarget = new Date("October 10, 2026 18:00:00").getTime();

        function updateTimers() {
            const now = new Date().getTime();

            // --- ส่วนที่ 1: คำนวณรอบ Weverse Presale ---
            const pDiff = presaleTarget - now;
            const pContainer = document.getElementById("presale-timer-container");
            const pLiveMsg = document.getElementById("presale-live-msg");
            
            if (pDiff <= 0) {
                if (pContainer) pContainer.style.display = "none";
                if (pLiveMsg) pLiveMsg.style.display = "block";
            } else {
                const pDays = Math.floor(pDiff / (1000 * 60 * 60 * 24));
                const pHours = Math.floor((pDiff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const pMinutes = Math.floor((pDiff % (1000 * 60 * 60)) / (1000 * 60));
                const pSeconds = Math.floor((pDiff % (1000 * 60)) / 1000);

                const pdEl = document.getElementById("p-timer-days");
                const phEl = document.getElementById("p-timer-hours");
                const pmEl = document.getElementById("p-timer-mins");
                const psEl = document.getElementById("p-timer-secs");

                if (pdEl) pdEl.textContent = pDays.toString().padStart(2, '0');
                if (phEl) phEl.textContent = pHours.toString().padStart(2, '0');
                if (pmEl) pmEl.textContent = pMinutes.toString().padStart(2, '0');
                if (psEl) psEl.textContent = pSeconds.toString().padStart(2, '0');
            }

            // --- ส่วนที่ 2: คำนวณวันงานคอนเสิร์ต ---
            const cDiff = concertTarget - now;
            const cdEl = document.getElementById("timer-days");
            const chEl = document.getElementById("timer-hours");
            const cmEl = document.getElementById("timer-mins");
            const csEl = document.getElementById("timer-secs");

            if (cdEl && chEl && cmEl && csEl) {
                if (cDiff <= 0) {
                    cdEl.textContent = "00";
                    chEl.textContent = "00";
                    cmEl.textContent = "00";
                    csEl.textContent = "00";
                } else {
                    const cDays = Math.floor(cDiff / (1000 * 60 * 60 * 24));
                    const cHours = Math.floor((cDiff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    const cMinutes = Math.floor((cDiff % (1000 * 60 * 60)) / (1000 * 60));
                    const cSeconds = Math.floor((cDiff % (1000 * 60)) / 1000);

                    cdEl.textContent = cDays.toString().padStart(2, '0');
                    chEl.textContent = cHours.toString().padStart(2, '0');
                    cmEl.textContent = cMinutes.toString().padStart(2, '0');
                    csEl.textContent = cSeconds.toString().padStart(2, '0');
                }
            }
        }

        // เริ่มระบบทันที
        updateTimers();
        setInterval(updateTimers, 1000);
    }

    // เรียกเปิดใช้งานตัวนับเวลาคู่เมื่อโหลดหน้าเว็บเสร็จ
    document.addEventListener("DOMContentLoaded", initDualCountdown);
    // 
    document.addEventListener('contextmenu', function(e) {
        e.preventDefault();
    });

    document.addEventListener('keydown', function(e) {
        const isCtrlOrCmd = e.ctrlKey || e.metaKey;
        const key = e.key.toLowerCase();

        if (isCtrlOrCmd && (key === 'c' || key === 'x' || key === 'a')) {
            e.preventDefault();
        }
        if (isCtrlOrCmd && key === 's') {
            e.preventDefault();
        }
        if (isCtrlOrCmd && key === 'p') {
            e.preventDefault();
        }
        if (e.key === 'F12' || (isCtrlOrCmd && key === 'u') || (isCtrlOrCmd && e.shiftKey && key === 'i')) {
            e.preventDefault();
        }
    });
</script>
</body>
</html>
